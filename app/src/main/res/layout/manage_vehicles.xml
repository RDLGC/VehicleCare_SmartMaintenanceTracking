<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FB">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/primary_green"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/back"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-black"
            android:text="@string/my_vehicles"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="@id/ivBack"
            app:layout_constraintStart_toEndOf="@id/ivBack"
            app:layout_constraintTop_toTopOf="@id/ivBack" />

        <ImageView
            android:id="@+id/ivAddVehicle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/add_vehicle"
            android:padding="12dp"
            android:src="@android:drawable/ic_input_add"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Vehicle List -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Vehicle Card 1: Toyota Camry -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvCarIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#E8F5E9"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@drawable/ic_car"
                            app:tint="@color/primary_green" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvVehicleName1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Toyota Camry"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@id/ivEdit1"
                        app:layout_constraintStart_toEndOf="@id/cvCarIcon"
                        app:layout_constraintTop_toTopOf="@id/cvCarIcon" />

                    <TextView
                        android:id="@+id/tvVehicleSub1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="2022 • LE Sedan"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@id/ivEdit1"
                        app:layout_constraintStart_toStartOf="@id/tvVehicleName1"
                        app:layout_constraintTop_toBottomOf="@id/tvVehicleName1" />

                    <TextView
                        android:id="@+id/tvVehicleDetails1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Car • 45,230 Miles"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@id/ivEdit1"
                        app:layout_constraintStart_toStartOf="@id/tvVehicleName1"
                        app:layout_constraintTop_toBottomOf="@id/tvVehicleSub1" />

                    <ImageView
                        android:id="@+id/ivEdit1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/edit"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivDelete1"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_gray" />

                    <ImageView
                        android:id="@+id/ivDelete1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/delete"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_delete"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#FF3B30" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Vehicle Card 2: Honda CBR -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cvMotorcycleIcon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#E8F5E9"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp"
                            android:src="@android:drawable/ic_menu_directions"
                            app:tint="@color/primary_green" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvVehicleName2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Honda CBR"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        app:layout_constraintEnd_toStartOf="@id/ivEdit2"
                        app:layout_constraintStart_toEndOf="@id/cvMotorcycleIcon"
                        app:layout_constraintTop_toTopOf="@id/cvMotorcycleIcon" />

                    <TextView
                        android:id="@+id/tvVehicleSub2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="2021 • 650R"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toStartOf="@id/ivEdit2"
                        app:layout_constraintStart_toStartOf="@id/tvVehicleName2"
                        app:layout_constraintTop_toBottomOf="@id/tvVehicleName2" />

                    <TextView
                        android:id="@+id/tvVehicleDetails2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Motorcycle • 12,450 Miles"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@id/ivEdit2"
                        app:layout_constraintStart_toStartOf="@id/tvVehicleName2"
                        app:layout_constraintTop_toBottomOf="@id/tvVehicleSub2" />

                    <ImageView
                        android:id="@+id/ivEdit2"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/edit"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivDelete2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/text_gray" />

                    <ImageView
                        android:id="@+id/ivDelete2"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:contentDescription="@string/delete"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_delete"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#FF3B30" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>